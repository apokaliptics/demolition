{
  "manifest_version": 3,
  "name": "Demolition",
  "version": "0.3.0",
  "description": "Hyper-minimalist text-first universal client. Blocks bloat, nukes CSS, bypasses launchers.",
  "permissions": [
    "activeTab",
    "declarativeNetRequest",
    "tabs"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "block_bloat",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["nuke.css"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": [
        "*://*.roblox.com/games/*",
        "*://www.roblox.com/games/*"
      ],
      "js": ["roblox.js"],
      "run_at": "document_end"
    },
    {
      "matches": [
        "*://*.netflix.com/*",
        "*://www.netflix.com/*"
      ],
      "js": ["netflix.js"],
      "run_at": "document_idle"
    }
  ]
}
