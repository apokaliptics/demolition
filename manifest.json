{
  "manifest_version": 3,
  "name": "Demolition",
  "version": "0.4.0",
  "description": "Hyper-minimalist text-first universal client. Blocks bloat and keeps pages readable.",
  "permissions": [
    "activeTab",
    "browsingData",
    "cookies",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "declarativeNetRequestWithHostAccess",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://duckduckgo.com/*",
    "https://html.duckduckgo.com/*",
    "https://music.youtube.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Demolition Dashboard",
    "default_popup": "popup.html"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "core_network",
        "enabled": false,
        "path": "rules/core-network.json"
      },
      {
        "id": "core_privacy",
        "enabled": false,
        "path": "rules/core-privacy.json"
      }
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["nuke.css"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": [
        "*://*.netflix.com/*",
        "*://www.netflix.com/*"
      ],
      "js": ["netflix.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["vim.js"],
      "run_at": "document_end"
    },
    {
      "matches": [
        "*://music.youtube.com/*"
      ],
      "js": ["ytmusic.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://youtube.com/*"
      ],
      "js": ["youtube.js"],
      "run_at": "document_end"
    }
  ]
}
